---
import Footer from '../../components/Footer.astro';
import ServicesContactSection from '../../components/ServicesContactSection.astro';
import ServicesGrid from '../../components/ServicesGrid.astro';
import ServicesPageHero from '../../components/ServicesPageHero.astro';
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n';

const locale = 'it';
const t = getTranslations(locale);
---

<Layout
	lang={locale}
	title={t.meta.services.title}
	description={t.meta.services.description}
	preloadImage="/images/leistungen-hero.jpg"
>
	<main class="bg-background text-text">
		<ServicesPageHero locale={locale} page="services" t={t.servicesPage.hero} />
		<ServicesGrid items={t.servicesPage.items} />
		<ServicesContactSection locale={locale} t={t.servicesPage.contact} />
	</main>
	<Footer locale={locale} />
</Layout>
