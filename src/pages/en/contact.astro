---
import ContactForm from '../../components/ContactForm.astro';
import ContactHero from '../../components/ContactHero.astro';
import ContactInfo from '../../components/ContactInfo.astro';
import ContactMap from '../../components/ContactMap.astro';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n';

const locale = 'en';
const t = getTranslations(locale);
---

<Layout lang={locale} title={t.meta.contact.title} description={t.meta.contact.description}>
	<main class="bg-background text-text">
		<ContactHero locale={locale} page="contact" t={t.contactPage.hero} />
		<ContactInfo t={t.contactPage.info} />
		<ContactForm t={t.contactPage.form} />
		<ContactMap t={t.contactPage.map} />
	</main>
	<Footer locale={locale} />
</Layout>
