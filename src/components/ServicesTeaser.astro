---
const services = [
	{
		title: 'Werkstatt & Technik',
		text: 'KFZ-Service, Revisionscenter, Reifendienst, Elektronik und Achsvermessung.',
		image: '/images/service.jpg',
		width: 2560,
		height: 1707,
	},
	{
		title: 'Karosserie & Autoglas',
		text: 'Karosseriearbeiten, Scheibenwechsel und Autoglas.',
		image: '/images/karosserie.jpg',
		width: 2560,
		height: 1707,
	},
	{
		title: 'Scheibenwechsel & Autoglas',
		text: 'Reparatur und Austausch von Autoglas – schnell und präzise.',
		image: '/images/autoglas.jpg',
		width: 2560,
		height: 1707,
	},
];
---

<section class="services-section relative overflow-hidden bg-background px-6 py-[clamp(5rem,10vw,10rem)] text-card sm:px-10 lg:px-16">
	<div class="services-bg-layer absolute inset-0 bg-[#050505]" aria-hidden="true"></div>
	<div class="relative z-10 mx-auto max-w-7xl">
		<div class="services-copy max-w-3xl">
			<p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] sm:text-sm">
				UNSERE LEISTUNGEN
			</p>
			<h2 class="text-[clamp(3rem,6vw,5.75rem)] font-semibold leading-[0.96] tracking-normal">
				Was wir bieten.
			</h2>
			<p class="mt-7 max-w-2xl text-lg leading-8">
				Drei Bereiche. Ein Anspruch: präziser Service für Ihr Fahrzeug.
			</p>
		</div>

		<div class="services-row mt-16 flex flex-col gap-5 lg:h-[520px] lg:flex-row">
			{
				services.map((service) => (
					<a
						href="/leistungen"
						class="service-card group relative flex min-h-[360px] overflow-hidden rounded-[32px] bg-[#151515] text-card shadow-[0_18px_46px_rgba(0,0,0,0.28)] sm:min-h-[420px] lg:h-full"
					>
						<img
							class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-[380ms] ease-in-out group-hover:scale-[1.04]"
							src={service.image}
							alt=""
							loading="eager"
							width={service.width}
							height={service.height}
							decoding="async"
							onerror="this.remove()"
						/>
						<div class="absolute inset-0 bg-linear-to-b from-black/10 via-black/25 to-black/85"></div>
						<div class="absolute bottom-8 left-8 right-8 w-auto shrink-0 pr-16 sm:bottom-10 sm:left-10 sm:w-60 sm:pr-0">
							<h3 class="text-[1.65rem] font-semibold leading-[1.08] tracking-normal sm:text-3xl">{service.title}</h3>
							<p class="mt-4 text-base leading-7 text-card/72">{service.text}</p>
						</div>
						<span
							class="absolute bottom-8 right-8 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-card/18 text-xl font-semibold text-card backdrop-blur-sm sm:bottom-10 sm:right-10"
							aria-hidden="true"
						>
							→
						</span>
					</a>
				))
			}
		</div>

		<div class="services-action mt-14">
			<a
				href="/leistungen"
				class="primary-button-hover inline-flex h-14 items-center justify-center rounded-pill bg-card px-8 text-sm font-semibold text-text hover:bg-card hover:text-text"
			>
				Alle Leistungen ansehen
			</a>
		</div>
	</div>
</section>

<style>
	.services-section {
		--services-bg-progress: 0;
		--services-heading-color: #111111;
		--services-muted-color: #6b7280;
	}

	.services-bg-layer {
		opacity: var(--services-bg-progress);
		pointer-events: none;
		z-index: 0;
	}

	.services-copy {
		color: var(--services-heading-color);
	}

	.services-copy p {
		color: var(--services-muted-color);
	}

	.services-copy h2 {
		color: var(--services-heading-color);
	}

	@media (min-width: 1024px) {
		.service-card {
			flex: 1 1 0;
			min-width: 0;
			transition: flex-grow 360ms ease-in-out;
		}

		.services-row:hover .service-card {
			flex-grow: 0.9;
		}

		.services-row .service-card:hover {
			flex-grow: 1.2;
		}
	}
</style>

<script>
	const servicesSection = document.querySelector('.services-section');

	if (servicesSection instanceof HTMLElement) {
		let ticking = false;

		const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
		const mix = (from, to, progress) => Math.round(from + (to - from) * progress);

		const setServicesProgress = (progress) => {
			const colorProgress = clamp((progress - 0.45) / 0.55, 0, 1);
			const headingColor = `rgb(${mix(17, 255, colorProgress)}, ${mix(17, 255, colorProgress)}, ${mix(17, 255, colorProgress)})`;
			const mutedColor = `rgb(${mix(107, 190, colorProgress)}, ${mix(114, 190, colorProgress)}, ${mix(128, 190, colorProgress)})`;

			servicesSection.style.setProperty('--services-bg-progress', progress.toFixed(3));
			servicesSection.style.setProperty('--services-heading-color', headingColor);
			servicesSection.style.setProperty('--services-muted-color', mutedColor);
		};

		const updateServicesProgress = () => {
			const rect = servicesSection.getBoundingClientRect();
			const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
			const start = viewportHeight * 0.12;
			const end = viewportHeight * -0.18;
			const progress = clamp((start - rect.top) / (start - end), 0, 1);

			setServicesProgress(progress);
			ticking = false;
		};

		const requestUpdate = () => {
			if (!ticking) {
				window.requestAnimationFrame(updateServicesProgress);
				ticking = true;
			}
		};

		updateServicesProgress();
		window.addEventListener('scroll', requestUpdate, { passive: true });
		window.addEventListener('resize', requestUpdate);
	}
</script>
