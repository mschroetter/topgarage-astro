---
import type { Translations } from '../i18n';

interface Props {
	t: Translations['home']['intro'];
}

const { t } = Astro.props;
---

<section class="bg-background px-6 py-section sm:px-10 lg:px-16">
	<div class="mx-auto grid max-w-7xl items-center gap-16 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-24">
		<div>
			<p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-text-secondary sm:text-sm">
				{t.eyebrow}
			</p>
			<h2 class="max-w-3xl text-[clamp(2.7rem,6.3vw,5.85rem)] font-semibold leading-[0.94] tracking-normal text-text">
				<Fragment set:html={t.headline} />
			</h2>
			<p class="mt-8 max-w-xl text-lg leading-8 text-text-secondary">
				{t.text}
			</p>
		</div>

		<div class="aspect-[4/3] overflow-hidden rounded-[32px] bg-card">
			<img
				class="h-full w-full object-cover"
				src="/images/workshop.jpg"
				alt={t.imageAlt}
				loading="eager"
				width="1707"
				height="2560"
				decoding="async"
			/>
		</div>
	</div>
</section>
