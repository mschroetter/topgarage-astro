---
import Header from './Header.astro';
---

<section class="relative isolate min-h-[78vh] overflow-hidden bg-text text-card">
	<img
		class="absolute inset-0 -z-20 h-full w-full object-cover"
		src="/images/leistungen-hero.jpg"
		alt="TopGarage Service in Meran-Sinich"
		loading="eager"
		fetchpriority="high"
		width="2560"
		height="1707"
		decoding="async"
	/>

	<div class="absolute inset-0 -z-10 bg-black/40"></div>
	<div class="absolute inset-0 -z-10 bg-linear-to-b from-black/10 via-black/20 to-black/60"></div>

	<Header />

	<div class="flex min-h-[78vh] items-end px-6 pb-16 pt-28 sm:px-10 sm:pb-20 lg:px-16 lg:pb-14">
		<div class="max-w-5xl">
			<p class="mb-5 text-xs font-semibold uppercase tracking-[0.28em] text-card/75 sm:text-sm">
				TOPGARAGE LEISTUNGEN
			</p>
			<h1 class="max-w-5xl text-[clamp(2.875rem,8.8vw,6.75rem)] font-semibold leading-[0.94] tracking-normal text-card">
				Service für jedes Detail.
			</h1>
			<p class="mt-8 max-w-2xl text-lg leading-8 text-card/82">
				Von Werkstatt und Technik bis Karosserie, Autoglas und Fahrzeughandel – persönliche Betreuung und höchste Qualität aus einer Hand.
			</p>
		</div>
	</div>
</section>
