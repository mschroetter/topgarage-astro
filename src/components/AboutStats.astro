---
import type { Translations } from '../i18n';

interface Props {
	t: Translations['aboutPage']['stats'];
}

const { t } = Astro.props;
---

<section class="company-stats bg-background px-6 py-[clamp(11.25rem,14vw,15rem)] sm:px-10 lg:px-16">
	<div class="mx-auto max-w-7xl">
		<p class="mb-16 text-xs font-semibold uppercase tracking-[0.28em] text-text-secondary sm:text-sm">
			{t.eyebrow}
		</p>

		<div class="grid gap-14 sm:grid-cols-2 lg:grid-cols-4 lg:gap-16">
			{
				t.items.map((item) => (
					<div class="stat-item">
						<p class="text-[clamp(5rem,7vw,6rem)] font-semibold leading-none tracking-normal text-text">
							{item.value}
						</p>
						<p class="mt-5 text-xs font-semibold uppercase tracking-[0.22em] text-text-secondary">
							{item.label}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>
