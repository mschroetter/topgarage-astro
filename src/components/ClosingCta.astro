---
import { route, type Locale } from '../i18n/routes';
import type { Translations } from '../i18n';

interface Props {
	locale?: Locale;
	t: Translations['home']['cta'];
}

const { locale = 'de', t } = Astro.props;
---

<section class="closing-cta bg-background px-6 py-[clamp(5rem,10vw,9rem)] text-card sm:px-10 lg:px-16">
	<div class="relative isolate mx-auto flex min-h-[75vh] max-w-[1600px] overflow-hidden rounded-[32px] bg-text px-6 py-24 sm:min-h-[82vh] sm:px-10 lg:px-16">
		<img
			class="absolute inset-0 -z-20 h-full w-full object-cover"
			src="/images/cta-bg.jpg"
			alt=""
			loading="eager"
			width="2560"
			height="1707"
			decoding="async"
		/>

		<div class="absolute inset-0 -z-10 bg-black/[0.48]"></div>
		<div class="absolute inset-0 -z-10 bg-linear-to-b from-black/10 via-black/30 to-black/65"></div>

		<div class="mx-auto flex w-full max-w-7xl items-center justify-center">
			<div class="cta-copy max-w-5xl text-center">
				<p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-card/75 sm:text-sm">
					{t.eyebrow}
				</p>
				<h2 class="text-[clamp(2.8rem,6.4vw,6.25rem)] font-semibold leading-[0.98] tracking-normal text-card">
					{t.headline}
				</h2>
				<p class="mx-auto mt-8 max-w-2xl text-base leading-7 text-card/82 sm:text-xl sm:leading-8">
					{t.text}
				</p>
				<div class="mt-10">
					<a
						href={route(locale, 'contact')}
						class="primary-button-hover inline-flex h-12 items-center justify-center rounded-pill bg-card px-7 text-sm font-semibold text-text hover:bg-card/90 hover:text-text sm:h-14 sm:px-8"
					>
						{t.button}
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
