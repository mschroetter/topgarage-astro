---
import type { Translations } from '../i18n';

interface Props {
	t: Translations['aboutPage']['values'];
}

const { t } = Astro.props;
---

<section class="bg-[#050505] px-6 py-section text-card sm:px-10 lg:px-16">
	<div class="mx-auto grid max-w-7xl gap-16 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:gap-24">
		<div>
			<p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-card/62 sm:text-sm">
				{t.eyebrow}
			</p>
			<h2 class="max-w-3xl text-[clamp(2.7rem,6.3vw,5.85rem)] font-semibold leading-[0.94] tracking-normal">
				<Fragment set:html={t.headline} />
			</h2>
		</div>

		<div class="grid gap-10 text-lg leading-8 text-card/68">
			{t.texts.map((text) => <p>{text}</p>)}
		</div>
	</div>
</section>
