---
import Header from './Header.astro';
import { route, type Locale, type PageKey } from '../i18n/routes';
import type { Translations } from '../i18n';

interface Props {
	locale?: Locale;
	page?: PageKey;
	t: Translations['home']['hero'];
}

const { locale = 'de', page = 'home', t } = Astro.props;
---

<section class="relative isolate h-screen overflow-hidden bg-text text-card">
	<video
		class="absolute inset-0 -z-20 h-full w-full object-cover"
		src="/videos/hero.mp4"
		autoplay
		muted
		loop
		playsinline
		preload="metadata"
		aria-label={t.videoLabel}
	></video>

	<div class="absolute inset-0 -z-10 bg-black/40"></div>
	<div class="absolute inset-0 -z-10 bg-linear-to-b from-black/10 via-black/20 to-black/60"></div>

	<Header locale={locale} page={page} />

	<div class="flex h-full items-end px-6 pb-16 pt-28 sm:px-10 sm:pb-20 lg:px-16 lg:pb-12">
		<div class="grid w-full items-end gap-10 lg:grid-cols-[minmax(0,1fr)_auto]">
			<div class="max-w-4xl">
				<p class="mb-5 text-xs font-semibold uppercase tracking-[0.28em] text-card/75 sm:text-sm">
					{t.eyebrow}
				</p>
				<h1 class="max-w-4xl text-[clamp(2.875rem,8.8vw,6.75rem)] font-semibold leading-[0.94] tracking-normal text-card">
					<Fragment set:html={t.headline} />
				</h1>
				<p class="mt-7 text-base font-medium text-card/85 sm:text-xl">
					{t.subline}
				</p>
				<div class="mt-9 flex flex-col gap-3 sm:flex-row">
					<a
						href={route(locale, 'contact')}
						class="primary-button-hover inline-flex h-12 items-center justify-center rounded-pill bg-card px-7 text-sm font-semibold text-text hover:bg-card/90 hover:text-text sm:h-14 sm:px-8"
					>
						{t.primary}
					</a>
					<a
						href={route(locale, 'services')}
						class="inline-flex h-12 items-center justify-center rounded-pill border border-card/55 bg-transparent px-7 text-sm font-semibold text-card transition-none hover:border-card hover:bg-transparent hover:text-card sm:h-14 sm:px-8"
					>
						{t.secondary}
					</a>
				</div>
			</div>

			<div class="justify-self-start text-left text-card/70 lg:justify-self-end lg:text-right">
				<p class="text-xs font-medium">{t.ratingLabel}</p>
				<p class="mt-1 text-sm font-semibold tracking-wide">★★★★★ 4.6</p>
			</div>
		</div>
	</div>

	<div class="hero-scroll-indicator absolute bottom-7 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 text-card/80">
		<span class="h-8 w-px bg-card/45"></span>
		<span class="text-xl leading-none" aria-hidden="true">↓</span>
		<span class="sr-only">{t.scrollLabel}</span>
	</div>
</section>

<style>
	.hero-scroll-indicator {
		animation: hero-scroll-float 2s ease-in-out infinite;
	}

	@keyframes hero-scroll-float {
		0%,
		100% {
			transform: translate(-50%, 0);
		}

		50% {
			transform: translate(-50%, 9px);
		}
	}
</style>
