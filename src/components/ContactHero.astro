---
import Header from './Header.astro';
---

<section class="relative bg-background px-6 pb-[clamp(5rem,9vw,9rem)] pt-[clamp(7rem,12vw,12rem)] text-text sm:px-10 lg:px-16">
	<Header theme="light" />

	<div class="mx-auto max-w-7xl">
		<p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-text-secondary sm:text-sm">
			KONTAKT
		</p>
		<h1 class="max-w-5xl text-[clamp(3rem,7.2vw,6.75rem)] font-semibold leading-[0.96] tracking-normal text-text">
			Wir freuen uns,<br />
			von Ihnen zu hören.
		</h1>
		<p class="mt-8 max-w-2xl text-lg leading-8 text-text-secondary">
			Ob Termin, Reparatur, Karosserie oder Autoglas – wir beraten Sie gerne persönlich.
		</p>
	</div>
</section>
