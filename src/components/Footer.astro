---
import { getTranslations } from '../i18n';
import { route, type Locale } from '../i18n/routes';

interface Props {
	locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);
---

<footer class="relative overflow-hidden border-t border-white/[0.08] bg-[#050505] px-6 pb-[clamp(6rem,12vw,12rem)] pt-[clamp(4rem,7vw,7rem)] text-card sm:px-10 lg:px-16">
	<div class="relative z-10 mx-auto grid max-w-7xl gap-14 lg:grid-cols-[minmax(0,1fr)_minmax(280px,0.45fr)] lg:gap-24">
		<div>
			<a href={route(locale, 'home')} class="text-sm font-semibold uppercase tracking-[0.24em] text-card transition-none hover:text-card">
				TopGarage
			</a>
			<div class="mt-9 space-y-5 text-base leading-7 text-card/62">
				<p>
					Reichstraße 63<br />
					39012 Meran-Sinich
				</p>
				<p>
					<a href="tel:+390473449835" class="transition-none hover:text-card">+39 0473 449 835</a><br />
					<a href="mailto:info@topgarage.it" class="transition-none hover:text-card">info@topgarage.it</a>
				</p>
			</div>
		</div>

		<nav aria-label={t.footer.aria}>
			<ul class="grid gap-4 text-base font-medium text-card/72">
				<li><a href={route(locale, 'services')} class="transition-none hover:text-card">{t.footer.services}</a></li>
				<li><a href={route(locale, 'about')} class="transition-none hover:text-card">{t.footer.about}</a></li>
				<li><a href={route(locale, 'contact')} class="transition-none hover:text-card">{t.footer.contact}</a></li>
				<li><a href={route(locale, 'contact')} class="transition-none hover:text-card">{t.footer.appointment}</a></li>
			</ul>
		</nav>
	</div>

	<div class="relative z-10 mx-auto mt-[clamp(4rem,8vw,8rem)] flex max-w-7xl flex-col gap-4 text-xs font-medium text-card/42 sm:flex-row sm:items-center sm:justify-between">
		<p>© TopGarage</p>
		<div class="flex gap-6">
			<a href={route('de', 'imprint')} class="transition-none hover:text-card/70">{t.footer.imprint}</a>
			<a href={route('de', 'privacy')} class="transition-none hover:text-card/70">{t.footer.privacy}</a>
		</div>
	</div>

	<p
		class="pointer-events-none absolute -bottom-[0.18em] left-1/2 z-0 -translate-x-1/2 select-none text-[clamp(5rem,22vw,30rem)] font-black leading-none tracking-[-0.06em] text-white/[0.08] sm:-bottom-[0.24em]"
		aria-hidden="true"
	>
		topgarage
	</p>
</footer>
