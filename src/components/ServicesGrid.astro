---
import ServicesCard from './ServicesCard.astro';
import type { Translations } from '../i18n';

interface Props {
	items: Translations['servicesPage']['items'];
}

const { items: services } = Astro.props;
---

<section class="px-6 py-section sm:px-10 lg:px-16">
	<div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-2">
		{
			services.map((service) => (
				<ServicesCard
					title={service.title}
					text={service.text}
					image={service.image}
					width={service.width}
					height={service.height}
					featured={service.featured}
				/>
			))
		}
	</div>
</section>
