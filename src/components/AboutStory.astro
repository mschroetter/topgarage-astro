---
import type { Translations } from '../i18n';

interface Props {
	t: Translations['aboutPage']['story'];
}

const { t } = Astro.props;
---

<section class="px-6 py-section sm:px-10 lg:px-16">
	<div class="mx-auto grid max-w-7xl gap-16 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-24">
		<div>
			<p class="mb-6 text-xs font-semibold uppercase tracking-[0.28em] text-text-secondary sm:text-sm">
				{t.eyebrow}
			</p>
			<h2 class="max-w-3xl text-[clamp(2.7rem,6.3vw,5.85rem)] font-semibold leading-[0.94] tracking-normal text-text">
				<Fragment set:html={t.headline} />
			</h2>
		</div>

		<div class="max-w-2xl self-end">
			<p class="text-lg leading-8 text-text-secondary">
				{t.text}
			</p>
		</div>
	</div>
</section>
